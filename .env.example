# Copy this file to ".env" on your computer and fill in your real values.
# The app reads these when you run or build it.
#
# EAS cloud builds: EXPO_PUBLIC_* for production is also set in eas.json (production profile)
# because .env is gitignored and is not uploaded to EAS.

# Where your backend API lives (no slash at the end).
# Documented Azure URL (HighScope at Home): see Family/Documents/MEBO-HIGHSCOPE-AT-HOME-PROJECT-RUNBOOK.md
EXPO_PUBLIC_API_URL=https://ca-backend-highscope-home.salmonrock-ff34e0c0.eastus2.azurecontainerapps.io

# Use "production" for store builds / real backend. "development" or empty for local testing.
EXPO_PUBLIC_ENV=production

# --- Google Maps (used by app.config.js at prebuild / expo run) ---
# Android native MapView needs a key in the manifest; set one of these before `expo run:android` or EAS build.
# Prefer GOOGLE_MAPS_ANDROID_API_KEY (EAS Secret) so the value is not inlined into the JS bundle.
GOOGLE_MAPS_ANDROID_API_KEY=
# Optional fallback if you only use a public env file locally:
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# Only if you use Google as the map provider on iOS (optional for MapKit default).
# GOOGLE_MAPS_IOS_API_KEY=
